<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_add_repair_service_wizard_form" model="ir.ui.view">
        <field name="name">workshop.add.repair.service.wizard.form</field>
        <field name="model">workshop.add.repair.service.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Repair Services">
                <group>
                    <field name="job_card_id"/>
                    <field name="repair_service_ids"
                           widget="many2many_tags"
                           domain="[('active', '=', True)]"
                           options="{'no_create': True}"/>
                </group>
                <footer>
                    <button name="action_add" type="object" string="Add"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_add_repair_service_wizard" model="ir.actions.act_window">
        <field name="name">Add Repair Services</field>
        <field name="res_model">workshop.add.repair.service.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_add_repair_service_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>
