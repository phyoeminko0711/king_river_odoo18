<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_remove_repair_service_wizard_form" model="ir.ui.view">
        <field name="name">workshop.remove.repair.service.wizard.form</field>
        <field name="model">workshop.remove.repair.service.wizard</field>
        <field name="arch" type="xml">
            <form string="Remove Repair Services">
                <group>
                    <field name="job_card_id"/>
                    <field name="job_card_service_ids"
                           widget="many2many_tags"
                           domain="[('job_card_id', '=', job_card_id)]"
                           options="{'no_create': True}"/>
                </group>
                <div class="alert alert-warning" role="alert">
                    Removing a Repair Service will also remove all related Product Option lines.
                </div>
                <footer>
                    <button name="action_remove_services"
                            type="object"
                            string="Remove"
                            class="btn-danger"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_remove_repair_service_wizard" model="ir.actions.act_window">
        <field name="name">Remove Repair Services</field>
        <field name="res_model">workshop.remove.repair.service.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_remove_repair_service_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>
