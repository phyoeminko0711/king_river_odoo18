<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vehicle_model_list" model="ir.ui.view">
        <field name="name">workshop.vehicle.model.list</field>
        <field name="model">workshop.vehicle.model</field>
        <field name="arch" type="xml">
            <list string="Vehicle Models">
                <field name="name"/>
                <field name="brand_id"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_vehicle_model_form" model="ir.ui.view">
        <field name="name">workshop.vehicle.model.form</field>
        <field name="model">workshop.vehicle.model</field>
        <field name="arch" type="xml">
            <form string="Vehicle Model">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <field name="name"/>
                        <field name="brand_id" options="{'no_create_edit': True}"/>
                        <field name="active" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vehicle_model" model="ir.actions.act_window">
        <field name="name">Vehicle Models</field>
        <field name="res_model">workshop.vehicle.model</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
