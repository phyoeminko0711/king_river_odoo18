<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vehicle_brand_list" model="ir.ui.view">
        <field name="name">workshop.vehicle.brand.list</field>
        <field name="model">workshop.vehicle.brand</field>
        <field name="arch" type="xml">
            <list string="Vehicle Brands">
                <field name="name"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_vehicle_brand_form" model="ir.ui.view">
        <field name="name">workshop.vehicle.brand.form</field>
        <field name="model">workshop.vehicle.brand</field>
        <field name="arch" type="xml">
            <form string="Vehicle Brand">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <field name="name"/>
                        <field name="active" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vehicle_brand" model="ir.actions.act_window">
        <field name="name">Vehicle Brands</field>
        <field name="res_model">workshop.vehicle.brand</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
