<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_customer_vehicle_list" model="ir.ui.view">
        <field name="name">workshop.customer.vehicle.list</field>
        <field name="model">workshop.customer.vehicle</field>
        <field name="arch" type="xml">
            <list string="Customer Vehicles">
                <field name="customer_id"/>
                <field name="plate_no"/>
                <field name="vehicle_brand_id"/>
                <field name="vehicle_model_id"/>
                <field name="color"/>
                <field name="mileage"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_customer_vehicle_form" model="ir.ui.view">
        <field name="name">workshop.customer.vehicle.form</field>
        <field name="model">workshop.customer.vehicle</field>
        <field name="arch" type="xml">
            <form string="Customer Vehicle">
                <sheet>
                    <widget name="web_ribbon"
                            title="Archived"
                            bg_color="text-bg-danger"
                            invisible="active"/>
                    <group>
                        <group>
                            <field name="customer_id" context="{'res_partner_search_mode': 'customer'}"/>
                            <field name="vehicle_brand_id" options="{'no_create_edit': True}"/>
                            <field name="vehicle_model_id"
                                   domain="[('brand_id', '=', vehicle_brand_id)]"
                                   options="{'no_create_edit': True}"/>
                            <field name="plate_no" placeholder="e.g. YGN-9K-1234"/>
                        </group>
                        <group>
                            <field name="chassis_no"/>
                            <field name="engine_no"/>
                            <field name="color"/>
                            <field name="mileage"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_customer_vehicle_search" model="ir.ui.view">
        <field name="name">workshop.customer.vehicle.search</field>
        <field name="model">workshop.customer.vehicle</field>
        <field name="arch" type="xml">
            <search string="Search Customer Vehicles">
                <field name="customer_id"/>
                <field name="plate_no"/>
                <field name="chassis_no"/>
                <field name="engine_no"/>
                <field name="vehicle_brand_id"/>
                <field name="vehicle_model_id"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived"
                        name="inactive"
                        domain="[('active', '=', False)]"
                        context="{'active_test': False}"/>
                <group expand="0" string="Group By">
                    <filter string="Customer" name="group_customer" context="{'group_by': 'customer_id'}"/>
                    <filter string="Brand" name="group_brand" context="{'group_by': 'vehicle_brand_id'}"/>
                    <filter string="Model" name="group_model" context="{'group_by': 'vehicle_model_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_customer_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="path">customer-vehicles</field>
        <field name="res_model">workshop.customer.vehicle</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_customer_vehicle_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create a customer vehicle</p>
            <p>Track customer-owned vehicles independently from products.</p>
        </field>
    </record>
</odoo>
