<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="view_move_form_inherit" model="ir.ui.view">
            <field name="name">account.move.form.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form" />
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='discount']" position="after">
                    <field name="discount_amt" optional="hide"/>
                </xpath>
                <xpath expr="//field[@name='line_ids']/list/field[@name='account_id']" position="after">
                    <field name="discount_amt" column_invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='tax_totals']" position="after">
                    <div class="d-flex float-end" colspan="2" groups="base.group_user">
                        <label for="total_discount"/>
                        <div>
                            <field name="total_discount" class="oe_inline"/>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>
</odoo>
