<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Inherit Form View to Modify it -->
    <record id="sale_order_line_wizard_form_inherit" model="ir.ui.view">
        <field name="name">sale.order.discount.wizard.inherit</field>
        <field name="model">sale.order.discount</field>
        <field name="inherit_id" ref="sale.sale_order_line_wizard_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='discount_percentage']" position="replace">
                <div class="o_row">
                    <field name="discount_percentage"
                    invisible="discount_type not in ('so_discount')" nolabel="1" widget="percentage"/>
                    <field name="discount_percentage"
                   invisible="discount_type not in ('sol_discount')" nolabel="1"/>
                    <field name="sol_disc_type"
                       invisible="discount_type not in ('sol_discount')" required="discount_type in ('sol_discount')" nolabel="1"/>
                </div>

            </xpath>
        </field>
    </record>
</odoo>
