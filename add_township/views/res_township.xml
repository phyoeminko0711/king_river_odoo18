<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

    <!-- Township -->
    <record id="view_res_township_tree" model="ir.ui.view">
        <field name="name">res.township.tree</field>
        <field name="model">res.township</field>
        <field name="arch" type="xml">
            <list string="Township" editable="bottom">
                <field name="name"/>
                 <field name="name_mm"/>
                <field name="code"/>
                <field name="state_id" options="{'no_create': True}"/>
                <field name="country_id" options="{'no_create': True}" readonly="1"/>
            </list>
        </field>
    </record>

    <record id="view_res_township_form" model="ir.ui.view">
        <field name="name">res.township.form</field>
        <field name="model">res.township</field>
        <field name="arch" type="xml">
            <form string="Township">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="district" options='{"no_open": True, "no_create": True}'/>
                        <field name="state_id" options='{"no_open": True, "no_create": True}'/>
                        <field name="country_id" options="{'no_create': True}" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_res_township_search" model="ir.ui.view">
        <field name="name">res.township.search</field>
        <field name="model">res.township</field>
        <field name="arch" type="xml">
            <search string="Country">
                <field name="name"/>
                <field name="country_id"/>
                <group string="Group By">
                    <filter name="groupby_country" string="Country" context="{'group_by': 'country_id'}"/>
                    <filter name="groupby_state" string="State" context="{'group_by': 'state_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_res_township" model="ir.actions.act_window">
        <field name="name">Townships</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.township</field>
        <field name="view_id" ref="view_res_township_tree"/>
        <!-- <field name="help">You can manage the different federal states you are working on from here. Each state is attached to one country.</field> -->
    </record>    

    <!-- MENU -->
    <menuitem id="menu_localization" name="Localization" sequence="12" web_icon="add_township,static/description/icon.png"/>
    <menuitem id="menu_country_partner" action="base.action_country" parent="menu_localization" sequence="1"/>
    <menuitem id="menu_country_state_partner" action="base.action_country_state" parent="menu_localization" sequence="2"/>
    <menuitem id="menu_township_partner" action="action_res_township" parent="menu_localization" sequence="2"/>  
    
</data>
</odoo>
