<?xml version="1.0" encoding="UTF-8" ?>
<odoo>


    <record id="res_country_district_view_tree" model="ir.ui.view">
        <field name="name">res.country.district.view.tree</field>
        <field name="model">res.country.district</field>
        <field name="arch" type="xml">
            <list string="Districts" editable="bottom">
                <field name="name" />
                <field name="code" />
                <field name="state_id" />
            </list>
        </field>
    </record>


        <record id="action_district_group" model="ir.actions.act_window">
            <field name="name">Districts</field>
            <field name="res_model">res.country.district</field>
            <field name="view_mode">list</field>
        </record>


        <menuitem id="district_menu_id"
                  action="action_district_group"
                  name="Districts"
                  parent="add_township.menu_localization"/>
</odoo>