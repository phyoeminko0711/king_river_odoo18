<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="sale_detail_report_view_form" model="ir.ui.view">
            <field name="name">sale.detail.report.view.form</field>
            <field name="model">sale.detail.report</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <group>
                            <field name="company_id"
                                   options="{ 'no_create': True, 'no_create_edit': True ,'no_open': True }"/>
                             <label for="date_from" string="From Date" />
                            <div class="o_row">
                                <field name="date_from" nolabel="1"/>
                                <label for="date_to" string="To Date" />
                                <field name="date_to" nolabel="1"/>
                            </div>
                            <field name="customer_ids"
                                   options="{ 'no_create': True, 'no_create_edit': True,'no_open': True }"
                                   widget="many2many_tags"/>
                            <field name="product_ids"
                                   options="{ 'no_create': True, 'no_create_edit': True,'no_open': True }"
                                   widget="many2many_tags"/>
                            <field name="user_ids"
                                   options="{ 'no_create': True, 'no_create_edit': True,'no_open': True }"
                                   widget="many2many_tags"/>

                            <field name="sale_team_ids"
                                   options="{ 'no_create': True, 'no_create_edit': True,'no_open': True }"
                                   widget="many2many_tags"/>
                        </group>
                        <group>
                        </group>
                    </group>
                    <footer>
                        <button name="print_report" type="object" string="Print XLSX" class="oe_highlight"/>
                        <button special="cancel" string="Cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        <record id="action_sale_detail_report" model="ir.actions.act_window">
            <field name="name">Sale Detail Report</field>
            <field name="res_model">sale.detail.report</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem
                action="action_sale_detail_report"
                id="menu_sale_detail_report"
                parent="sale.menu_sale_report"
        />

    </data>
</odoo>