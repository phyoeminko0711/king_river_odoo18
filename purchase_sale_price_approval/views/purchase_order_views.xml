<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_sale_price_updates" model="ir.ui.view">
        <field name="name">purchase.order.form.sale.price.updates</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button type="object" name="action_view_sale_price_updates" class="oe_stat_button" icon="fa-tags">
                    <field name="sale_price_update_count" widget="statinfo" string="Sale Price Updates"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
