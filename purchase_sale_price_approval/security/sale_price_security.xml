<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_sale_price_manager" model="res.groups">
        <field name="name">Sale Price Manager</field>
        <field name="category_id" ref="base.module_category_inventory_purchase"/>
    </record>

    <record id="group_sale_price_admin" model="res.groups">
        <field name="name">Sale Price Administrator</field>
        <field name="category_id" ref="base.module_category_inventory_purchase"/>
        <field name="implied_ids" eval="[(4, ref('purchase_sale_price_approval.group_sale_price_manager'))]"/>
    </record>

    <record id="sale_price_rule_company_rule" model="ir.rule">
        <field name="name">Sale Price Rule multi-company</field>
        <field name="model_id" ref="model_sale_price_rule"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('purchase_sale_price_approval.group_sale_price_manager')), (4, ref('purchase_sale_price_approval.group_sale_price_admin'))]"/>
    </record>

    <record id="sale_price_rule_line_company_rule" model="ir.rule">
        <field name="name">Sale Price Rule Line multi-company</field>
        <field name="model_id" ref="model_sale_price_rule_line"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('purchase_sale_price_approval.group_sale_price_manager')), (4, ref('purchase_sale_price_approval.group_sale_price_admin'))]"/>
    </record>

    <record id="sale_price_update_company_rule" model="ir.rule">
        <field name="name">Sale Price Update multi-company</field>
        <field name="model_id" ref="model_sale_price_update"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('purchase_sale_price_approval.group_sale_price_manager')), (4, ref('purchase_sale_price_approval.group_sale_price_admin'))]"/>
    </record>

    <record id="sale_price_history_company_rule" model="ir.rule">
        <field name="name">Sale Price History multi-company</field>
        <field name="model_id" ref="model_sale_price_history"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('purchase_sale_price_approval.group_sale_price_manager')), (4, ref('purchase_sale_price_approval.group_sale_price_admin'))]"/>
    </record>
</odoo>
